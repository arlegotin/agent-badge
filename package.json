{
  "name": "agent-badge",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core/tsconfig.json packages/agent-badge/tsconfig.json packages/create-agent-badge/tsconfig.json packages/testkit/tsconfig.json",
    "test": "vitest",
    "typecheck": "tsc -b --pretty false packages/core/tsconfig.json packages/agent-badge/tsconfig.json packages/create-agent-badge/tsconfig.json packages/testkit/tsconfig.json",
    "pack:check": "npm pack --workspace packages/core --dry-run --json && npm pack --workspace packages/agent-badge --dry-run --json && npm pack --workspace packages/create-agent-badge --dry-run --json",
    "smoke:pack": "bash scripts/smoke/verify-packed-install.sh",
    "docs:check": "bash scripts/verify-docs.sh",
    "changeset": "changeset",
    "release": "changeset publish",
    "dev:agent-badge": "tsx packages/agent-badge/src/cli/main.ts",
    "dev:create-agent-badge": "tsx packages/create-agent-badge/src/index.ts",
    "agent-badge:init": "agent-badge init",
    "agent-badge:refresh": "agent-badge refresh --hook pre-push --fail-soft"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.0.0",
    "vitest": "^3.2.0",
    "agent-badge": "latest"
  }
}
