{
  "name": "create-agent-badge",
  "version": "1.1.18",
  "description": "npm initializer for bootstrapping agent-badge in a repository.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/arlegotin/agent-badge#readme",
  "bugs": {
    "url": "https://github.com/arlegotin/agent-badge/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/arlegotin/agent-badge"
  },
  "packageManager": "npm@11.6.0",
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || ^24.0.0"
  },
  "keywords": [
    "initializer",
    "create",
    "badge",
    "cli",
    "github",
    "ai"
