{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@agent-badge/core": [
        "packages/core/src/index.ts"
      ],
      "@agent-badge/testkit": [
        "packages/testkit/src/index.ts"
      ],
      "agent-badge": [
        "packages/agent-badge/src/index.ts"
      ]
    },
    "strict": true,
    "declaration": true,
    "composite": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "skipLibCheck": true
  }
}
